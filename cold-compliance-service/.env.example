# Runtime
NODE_ENV=development
PORT=3100
LOG_LEVEL=info

# PostgreSQL (dedicated DB for this service)
DB_HOST=postgres
DB_PORT=5432
DB_USER=horizonst
DB_PASSWORD=change_me
DB_NAME=cold_compliance

# MQTT
MQTT_URL=mqtt://vernemq:1883
MQTT_CLIENT_ID=cold-compliance-service
MQTT_USERNAME=change_me
MQTT_PASSWORD=change_me
MQTT_SUB_TOPICS=gw/+/publish
MQTT_COMMAND_TOPIC_TEMPLATE=gw/{gatewayMac}/subscribe

# Presence timeout
PRESENCE_EXIT_TIMEOUT_MS=45000
PRESENCE_SWEEP_INTERVAL_MS=5000
REENTRY_REMINDER_INTERVAL_MS=180000

# Compliance rules
MAX_CONTINUOUS_MINUTES=45
PRE_ALERT_MINUTES=40
REQUIRED_BREAK_MINUTES=15
MAX_DAILY_MINUTES=360
INCIDENT_GRACE_MINUTES=2
DEAD_MAN_DEFAULT_MINUTES=3
BATTERY_ALERT_THRESHOLD=20

# Sync
SYNC_BATCH_SIZE=100

# Tag control
TAG_CONTROL_ENABLED=true
TAG_CONTROL_DEFAULT_TIMEOUT_MS=8000
TAG_CONTROL_MAX_RETRIES=2
TAG_CONTROL_MSG_ID_START=1100
TAG_CONTROL_REQUIRE_REPLY=true
TAG_CONTROL_DEDUP_WINDOW_MS=10000
TAG_CONTROL_GATEWAY_STRATEGY=hybrid
TAG_ALARM_PHYSICAL_ENABLED=true
TAG_SESSION_PASSWORD=Moko4321
TAG_ALARM_CONNECT_TIMEOUT_MS=12000
TAG_ALARM_CONNECT_MAX_RETRIES=2
TAG_ALARM_ACTION_TIMEOUT_MS=8000
TAG_ALARM_POST_CONNECT_DELAY_MS=1200
TAG_ALARM_BETWEEN_ACTION_DELAY_MS=500
TAG_ALARM_DUAL_ACTION_WAIT_MS=60000

# Mail (password recovery)
MAIL_ENABLED=true
MAIL_HOST=mail
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=no_reply@example.invalid
MAIL_PASSWORD=change_me
MAIL_FROM=no_reply@example.invalid
MAIL_EHLO_DOMAIN=example.invalid
MAIL_TLS_REJECT_UNAUTHORIZED=false
APP_BASE_URL=http://localhost:3100
