{
  "name": "cold-compliance-service",
  "version": "0.1.0",
  "description": "Cold room compliance monitoring service for HorizonST",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "mqtt": "^5.10.3",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.5",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "@types/pdfkit": "^0.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
