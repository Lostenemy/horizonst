{
  "name": "horizonst-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "build": "npm run build:web && tsc -p tsconfig.build.json",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "helmet": "8.0.0",
    "pg": "8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vite": "6.0.6"
  }
}
